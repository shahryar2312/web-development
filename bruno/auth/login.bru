meta {
  name: Login
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/auth/login
  body: json
  auth: none
}

body:json {
  {
    "email": "testuser@example.com",
    "password": "Test1234!"
  }
}

script:post-response {
  const body = res.getBody();
  if (body.success) {
    bru.setVar("accessToken", body.data.accessToken);
  }
}
