NODE_ENV=development
PORT=5000

# MongoDB connection string — use your local URI or a MongoDB Atlas URI
MONGO_URI=mongodb://localhost:27017/gamerhub

# JWT secrets — use long, random strings in production
JWT_ACCESS_SECRET=change_this_access_secret
JWT_REFRESH_SECRET=change_this_refresh_secret

# Token expiry
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Frontend origin for CORS (React dev server default)
CLIENT_ORIGIN=http://localhost:3000

# Cloudinary (for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# SMTP (for emails/password reset)
# For dev/test, you can use Mailtrap or a Gmail App Password
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
FROM_EMAIL=noreply@gamerhub.com
FROM_NAME=GamerHub
