{
  "info": {
    "name": "GamerHub API - E2E",
    "description": "Complete Postman collection for the GamerHub Backend, fully dynamic and chained.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "hubId",
      "value": "change_me",
      "type": "string"
    },
    {
      "key": "postId",
      "value": "change_me",
      "type": "string"
    },
    {
      "key": "commentId",
      "value": "change_me",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "change_me",
      "type": "string"
    },
    {
      "key": "testEmail",
      "value": "{{$randomEmail}}",
      "type": "string"
    },
    {
      "key": "testUsername",
      "value": "User_{{$randomInt}}",
      "type": "string"
    },
    {
      "key": "testPassword",
      "value": "Password123!",
      "type": "string"
    },
    {
      "key": "resetToken",
      "value": "change_me",
      "type": "string"
    },
    {
      "key": "notificationId",
